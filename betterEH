crosshair = Window:Tab({
    Title = "Crosshair",
    Icon = "crosshair"
})

local crosshaircolor = Color3.new(1,1,1)
local crosshairthickness = 2
local crosshairlength = 16
local crosshairgap = 2
local usecrosshair = false
local staticcrosshair = false
local nofadecrosshair = false

local cross
for _, gui in pairs(localPlayer.PlayerGui:GetChildren()) do
    local first = gui:GetChildren()[1]
    if first then
        local target = first:FindFirstChild("5")
        if target and target:IsA("ImageLabel") and target.Image == "rbxassetid://285779644" then
            cross = first
            break
        end
    end
end

if not cross then return end

local p1 = cross:FindFirstChild("1") --up
local p2 = cross:FindFirstChild("2") --left
local p3 = cross:FindFirstChild("3") --down
local p4 = cross:FindFirstChild("4") --right
local lastframe = 25

if not (p1 and p2 and p3 and p4) then return end

RunService.RenderStepped:Connect(function(dt)
    if not usecrosshair then return end

    local t = crosshairthickness
    local l = crosshairlength
    local g = crosshairgap

    p1.BackgroundColor3 = crosshaircolor
    p2.BackgroundColor3 = crosshaircolor
    p3.BackgroundColor3 = crosshaircolor
    p4.BackgroundColor3 = crosshaircolor

    p1.Size = UDim2.new(0, t, 0, l)
    p2.Size = UDim2.new(0, l, 0, t)
    p3.Size = UDim2.new(0, t, 0, l)
    p4.Size = UDim2.new(0, l, 0, t)

    if cross.Size.X.Offset < l + g*2 or staticcrosshair then  
        cross.Size = UDim2.new(0, l + g*2, 0, l + g*2)
    end

    if 25 > l + g*2 and cross.Size.X.Offset < 26 and p1.Transparency < 0.1 then
        lastframe = math.max(l + g*2, lastframe - dt*75)
        cross.Size = UDim2.new(0, lastframe, 0, lastframe)
    end

    if cross.Size.X.Offset > 26 then
        lastframe = 25
    end

    if p1.Transparency < 1 and nofadecrosshair then
        p1.Transparency = 0
        p2.Transparency = 0
        p3.Transparency = 0
        p4.Transparency = 0
    end

end)

