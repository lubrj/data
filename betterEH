local function getConfigs()
    if not WindUI.Configs then return {} end
    local list = {}
    for name, _ in pairs(WindUI.Configs) do
        table.insert(list, name)
    end
    table.sort(list)
    return list
end

local function refreshDropdown()
    local configs = getConfigs()
    configselect:Refresh(configs)
    configselect:Set(nil)
    selectedConfig = nil
end

configselect = configtab:Dropdown({
